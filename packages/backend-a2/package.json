{
  "name": "@trac/backend-a2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":             "ts-node-dev --respawn --transpile-only src/index.ts",
    "build":           "tsc",
    "start":           "node dist/index.js",
    "prisma:migrate":  "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:studio":   "prisma studio --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "amqplib":        "^0.10.3",
    "cors":           "^2.8.5",
    "dotenv":         "^16.3.1",
    "express":        "^4.18.2",
    "helmet":         "^7.1.0",
    "morgan":         "^1.10.0",
    "uuid":           "^9.0.1",
    "zod":            "^3.22.4"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/cors":    "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan":  "^1.9.9",
    "@types/node":    "^20.10.4",
    "@types/uuid":    "^9.0.7",
    "prisma":         "^5.7.1",
    "ts-node-dev":    "^2.0.0",
    "typescript":     "^5.3.3"
  }
}
